.mypy_cache/

# Package managers
# NOTE: package-lock.json MUST be committed — Dockerfile uses `npm ci` which
# requires the lockfile for reproducible builds. Railway/Fly build fails without it.
yarn.lock
pnpm-lock.yaml

# Misc
*.bak
*.bak.*
*.tmp
.cache/
temp/
.vercel
.env*.local

# Generated artifacts / staging (duplicates of tracked files)
/artifacts/

# Runtime data at repo root
/dre_final.json
/production_logs.json
/cmv_by_event.json
/catalog_products.json
/inventory_batches.json
/dashboard_data.json

# Runtime outputs from Python engines (DRE, CMV, audit)
/kitchen_data/*.json
/output/*.csv

# Obsidian workspace state (vault content is tracked, but per-user UI state is not)
vault/.obsidian/workspace*.json
vault/.obsidian/app.json
vault/.obsidian/appearance.json
vault/.obsidian/core-plugins.json
vault/.obsidian/community-plugins.json
vault/.obsidian/templates.json
