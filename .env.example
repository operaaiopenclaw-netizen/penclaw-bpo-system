# ============================================================
# ORKESTRA FINANCE BRAIN - Environment Configuration
# ============================================================

# App Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=openclaw-api
APP_VERSION=1.0.0

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openclaw
DATABASE_SSL=false

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty
# Options: pretty, json, silent

# Swagger/OpenAPI
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/docs

# Feature Flags
ENABLE_MEMORY=true
ENABLE_APPROVALS=true
ENABLE_AUDIT=true
ENABLE_CALIBRATION=true

# Python Engines Integration
PYTHON_ENGINES_PATH=./engines
PYTHON_EXEC=python3

# Storage
STORAGE_TYPE=local
STORAGE_URL=./storage
# For S3: s3://bucket-name/path
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_REGION=us-east-1

# Email (for notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-password
# SMTP_FROM=Orkestra <noreply@orkestra.ai>

# Monitoring
SENTRY_DSN=
HONEYCOMB_API_KEY=

# Development Only
DEBUG=true
TS_NODE_DEV=true

# Production Only (uncomment when deploying)
# NODE_ENV=production
# PORT=80
# LOG_LEVEL=warn
# SWAGGER_ENABLED=false
# DATABASE_SSL=true
ASE_SSL=true
ENABLED=false
# DATABASE_SSL=true
