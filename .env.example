# ============================================================
# Orkestra · Example environment
# Copy to .env and fill in. Never commit real secrets.
# ============================================================

# ---- App ----
NODE_ENV=development              # development | production | test
PORT=3010
LOG_LEVEL=info                    # debug | info | warn | error
CORS_ORIGIN=http://localhost:3000,https://app.orkestra.com

# ---- Multi-tenant ----
DEFAULT_TENANT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# ---- Database ----
# Managed Postgres URL. Local dev: postgres:postgres@localhost:5432/orkestra
DATABASE_URL=postgresql://user:pass@host:5432/orkestra

# ---- Redis (BullMQ) ----
# Currently hardcoded to 127.0.0.1:6379 in src/queue.ts; override there for prod.

# ---- Auth / JWT ----
# Must be at least 32 chars. Rotate every 90 days (see docs/RUNBOOK.md §5).
JWT_SECRET=replace-me-with-32-chars-or-more-random-string
JWT_REFRESH_SECRET=replace-me-with-another-32-chars-random-string
JWT_EXPIRES_IN=1d

# ---- Webhook HMAC ----
# Required in production for /operations/webhooks/* (event/consumption/production).
# Shared with upstream systems that POST signed payloads.
WEBHOOK_HMAC_SECRET=replace-me-hmac-shared-secret

# ---- Telegram channel ----
# In prod, TELEGRAM_ALLOWED_CHATS is required — unlisted chat_ids are rejected (403).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHATS=           # comma-separated chat_ids: "-100123,456"

# ---- Generic alert webhook ----
WEBHOOK_URL=                      # e.g. Slack/Discord incoming webhook
WEBHOOK_AUTH=                     # optional Authorization header value

# ---- Storage ----
STORAGE_TYPE=local                # local | s3
ARTIFACTS_DIR=./storage/artifacts

# ---- AI providers ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                   # only used by vetAgent

# ---- Cron tuning ----
ALERT_HORIZON_DAYS=14             # how far ahead cron_evaluate_alerts looks
